# ---- Byte-compiled / cache files ----
__pycache__/
*.py[cod]
*$py.class
*.so

# ---- Virtual environments ----
venv/
env/
.venv/
ENV/

# ---- Environment variables / secrets ----
.env
.env.local

# ---- Packaging ----
*.egg-info/
dist/
build/
*.egg

# ---- Logs (keep the folder, ignore generated log files) ----
logs/*.log
logs/*.log.*
!logs/.gitkeep

# ---- Scraped output data (keep the folder, ignore generated data) ----
output/*.csv
output/*.json
!output/.gitkeep

# ---- Jupyter ----
.ipynb_checkpoints/

# ---- IDE / editor ----
.vscode/
.idea/
*.swp
*.swo

# ---- OS ----
.DS_Store
Thumbs.db

# ---- Testing / coverage ----
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/
